{
  "name": "better-auth-no-disposable-emails",
  "version": "0.1.1",
  "description": "better-auth plugin to prevent disposable emails",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/koslib/better-auth-no-disposable-emails.git"
  },
  "keywords": [
    "better-auth",
    "plugin",
    "disposable-email",
    "email-validation",
    "mailchecker"
  ],
  "author": "koslib",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/koslib/better-auth-no-disposable-emails/issues"
  },
  "homepage": "https://github.com/koslib/better-auth-no-disposable-emails#readme",
  "peerDependencies": {
    "better-auth": ">=1.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "better-auth": "^1.4.19",
    "better-sqlite3": "^12.6.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "mailchecker": "^6.0.19"
  }
}
